<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" version="21.0.0">

  <!-- PAGE 1: BEFORE — Monolithic Pizza Shop -->
  <diagram id="page1" name="Before — Monolith (Pizza Shop)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" pageWidth="1169" pageHeight="827">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="t1" value="&lt;b&gt;BEFORE: Monolithic Architecture&lt;/b&gt;&lt;br&gt;🍕 Example: A Pizza Shop Website" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="620" height="50" as="geometry" />
        </mxCell>

        <!-- Customer -->
        <mxCell id="customer" value="&lt;b&gt;👤 Customer&lt;/b&gt;&lt;br&gt;Opens pizzashop.com" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="460" y="90" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow down -->
        <mxCell id="e0" value="1 request" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;fontStyle=1;" edge="1" source="customer" target="monolith" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Monolith box -->
        <mxCell id="monolith" value="&lt;b&gt;🏢 pizza_app.py  —  One single file, one server&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;verticalAlign=top;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="210" width="820" height="340" as="geometry" />
        </mxCell>

        <!-- Order module -->
        <mxCell id="mod_order" value="&lt;b&gt;🛒 Order Module&lt;/b&gt;&lt;br&gt;Take order, add to cart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="300" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Payment module -->
        <mxCell id="mod_pay" value="&lt;b&gt;💳 Payment Module&lt;/b&gt;&lt;br&gt;Charge the customer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="300" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Delivery module -->
        <mxCell id="mod_del" value="&lt;b&gt;🚚 Delivery Module&lt;/b&gt;&lt;br&gt;Assign delivery driver" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="780" y="300" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Coupling arrows -->
        <mxCell id="ec1" value="calls directly" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;dashed=1;fontSize=10;fontColor=#b85450;" edge="1" source="mod_order" target="mod_pay" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec2" value="calls directly" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;dashed=1;fontSize=10;fontColor=#b85450;" edge="1" source="mod_pay" target="mod_del" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Shared DB -->
        <mxCell id="db" value="&lt;b&gt;🗄️ One Shared Database&lt;/b&gt;&lt;br&gt;orders + payments + deliveries all in same DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="330" y="430" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ed1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d79b00;" edge="1" source="mod_order" target="db" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d79b00;" edge="1" source="mod_pay" target="db" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed3" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d79b00;" edge="1" source="mod_del" target="db" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Problems -->
        <mxCell id="p1" value="❌ Payment bug?&lt;br&gt;Whole site goes down.&lt;br&gt;Can't order pizza at all." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="300" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="❌ New pizza added?&lt;br&gt;Redeploy ALL modules.&lt;br&gt;Site offline 10 mins." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="420" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="❌ Weekend rush?&lt;br&gt;Can't scale only orders.&lt;br&gt;Must scale everything." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="300" width="160" height="70" as="geometry" />
        </mxCell>

        <!-- Bottom note -->
        <mxCell id="note1" value="🍕 Real world: One cook does ordering, cooking, billing AND delivery. If he calls in sick — shop is closed." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#9673a6;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="580" width="720" height="45" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- PAGE 2: AFTER — FastAPI Decoupled Pizza Shop -->
  <diagram id="page2" name="After — FastAPI Decoupled (Pizza Shop)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" pageWidth="1169" pageHeight="827">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="t2" value="&lt;b&gt;AFTER: FastAPI Decoupled Architecture&lt;/b&gt;&lt;br&gt;🍕 Same Pizza Shop — now each part is independent" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="620" height="50" as="geometry" />
        </mxCell>

        <!-- Customer -->
        <mxCell id="customer2" value="&lt;b&gt;👤 Customer&lt;/b&gt;&lt;br&gt;Opens pizzashop.com" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="460" y="80" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Uvicorn + FastAPI label -->
        <mxCell id="uv" value="&lt;b&gt;Uvicorn (ASGI Server)&lt;/b&gt; receives request → FastAPI Router decides which service to call" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="190" width="500" height="45" as="geometry" />
        </mxCell>

        <mxCell id="e_cuv" value="HTTP Request" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;fontStyle=1;" edge="1" source="customer2" target="uv" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrows fan out -->
        <mxCell id="ef1" value="POST /orders" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontSize=10;fontStyle=1;" edge="1" source="uv" target="svc_order" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ef2" value="POST /pay" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontSize=10;fontStyle=1;" edge="1" source="uv" target="svc_pay" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ef3" value="POST /delivery" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontSize=10;fontStyle=1;" edge="1" source="uv" target="svc_del" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SERVICE 1: Order -->
        <mxCell id="svc_order" value="&lt;b&gt;🛒 Order Service&lt;/b&gt;&lt;br&gt;orders.py — port 8001&lt;br&gt;&lt;br&gt;@app.post('/orders')&lt;br&gt;  → validate with Pydantic&lt;br&gt;  → save to Orders DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontFamily=Courier New;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="290" width="240" height="150" as="geometry" />
        </mxCell>

        <!-- SERVICE 2: Payment -->
        <mxCell id="svc_pay" value="&lt;b&gt;💳 Payment Service&lt;/b&gt;&lt;br&gt;payments.py — port 8002&lt;br&gt;&lt;br&gt;@app.post('/pay')&lt;br&gt;  → validate with Pydantic&lt;br&gt;  → save to Payments DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontFamily=Courier New;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="460" y="290" width="240" height="150" as="geometry" />
        </mxCell>

        <!-- SERVICE 3: Delivery -->
        <mxCell id="svc_del" value="&lt;b&gt;🚚 Delivery Service&lt;/b&gt;&lt;br&gt;delivery.py — port 8003&lt;br&gt;&lt;br&gt;@app.post('/delivery')&lt;br&gt;  → validate with Pydantic&lt;br&gt;  → save to Delivery DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontFamily=Courier New;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="820" y="290" width="240" height="150" as="geometry" />
        </mxCell>

        <!-- Individual DBs -->
        <mxCell id="db1" value="🗄️ Orders DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="480" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="db2" value="🗄️ Payments DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="510" y="480" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="db3" value="🗄️ Delivery DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="480" width="140" height="40" as="geometry" />
        </mxCell>

        <mxCell id="edb1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;" edge="1" source="svc_order" target="db1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="edb2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;" edge="1" source="svc_pay" target="db2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="edb3" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;" edge="1" source="svc_del" target="db3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Benefits -->
        <mxCell id="b1" value="✅ Payment down?&lt;br&gt;Orders still work!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="560" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="✅ New pizza menu?&lt;br&gt;Redeploy ONLY Order service." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="560" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="✅ Weekend rush?&lt;br&gt;Scale ONLY Order service." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="560" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Bottom analogy -->
        <mxCell id="note2" value="🍕 Real world: Separate cook, cashier, and delivery driver. Cashier sick? Cook and driver still work. That's decoupling." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#9673a6;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="640" width="760" height="45" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
